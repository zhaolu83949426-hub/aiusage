{
  "name": "@juliantanx/aiusage",
  "version": "1.0.3",
  "type": "module",
  "description": "Track and analyze AI coding assistant usage across Claude Code, Codex, and more",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "aiusage": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prepack": "cp ../../README.md README.md",
    "build": "tsup && node scripts/copy-web.js",
    "dev": "tsx src/index.ts serve",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@aiusage/core": "workspace:*",
    "@aiusage/web": "workspace:*",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^25.7.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
